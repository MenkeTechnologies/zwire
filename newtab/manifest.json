{
  "manifest_version": 3,
  "name": "zwire New Tab",
  "key": "",
  "short_name": "zwire-newtab",
  "version": "1.0.7",
  "description": "Cyberpunk new-tab page for zwire \u2014 neon clock, omnibox search, quick-launch tiles.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "nativeMessaging",
    "tabs",
    "history"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "externally_connectable": {
    "ids": [
      "omcgnnjfmbmpdlofklbpddkhnfibfhgg"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "newtab.html",
        "newtab.css",
        "newtab.js",
        "palette.js",
        "tmux-pane.js",
        "scheme-sync.js",
        "schemes.js",
        "fonts/*",
        "lib/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
