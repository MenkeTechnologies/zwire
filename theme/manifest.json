{
  "manifest_version": 3,
  "name": "zwire Cyberpunk",
  "short_name": "zwire-theme",
  "version": "1.0.0",
  "description": "Cyberpunk chrome theme for zwire — the strykelang HUD palette applied to frame, toolbar, tabs and NTP.",
  "theme": {
    "colors": {
      "frame":             [24, 11, 46],
      "frame_inactive":    [13, 6, 26],
      "frame_incognito":   [10, 4, 22],
      "toolbar":           [28, 14, 52],
      "tab_text":          [255, 42, 109],
      "tab_background_text":[154, 134, 200],
      "bookmark_text":     [224, 240, 255],
      "button_background": [28, 14, 52],
      "ntp_background":    [5, 5, 10],
      "ntp_text":          [224, 240, 255],
      "ntp_link":          [5, 217, 232],
      "ntp_section":       [13, 13, 26]
    },
    "tints": {
      "buttons": [0.5, 0.7, 0.55]
    },
    "properties": {
      "ntp_background_alignment": "center",
      "ntp_logo_alternate": 1
    }
  }
}
