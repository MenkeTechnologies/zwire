 namespace audio {
 
+// ---------------------------------------------------------------------------
+// zwire HUD — browser-wide output EQ (fork patch 0022).
+//
+// Applied in OutputController::OnMoreData(), right after the renderer's PCM is
+// read into `dest`. This is the audio service's per-stream output pull: EVERY
+// stream that reaches the OS output device — HTMLMediaElement, MSE (YouTube),
+// Web Audio, WebRTC — passes through here, so the HUD equalizer shapes all
+// browser audio. (The renderer-side AudioRendererMixer only carries some
+// streams, which is why patching it missed real tab audio.)
+//
+// Config comes once from the ZWIRE_AUDIO_EQ environment variable (exported by
+// bin/zwire; the audio service process inherits it), format:
+//   "preampDb;type,freq,gainDb,q;..."   type in {lowshelf, peaking, highshelf}
+// Empty / "off" / "0" => bypass. Per-stream biquad state; immutable config =>
+// lock-free on the audio device thread. Same RBJ math as the HUD dashboard.
+// ---------------------------------------------------------------------------
+// zwire live config (fork patch 0024) --------------------------------------
+// Immutable parsed config (preamp + bands; sample-rate independent). Swapped
+// atomically by SetZwireEqConfig(), invoked on the audio-service main thread
+// from mojom AudioService::SetZwireEqConfig — which the browser process pushes
+// whenever $STATE/audio-eq changes (the audio sandbox can't read the file in
+// this process). Each OutputController's ZwireAudioEq reads the current snapshot
+// every block and recomputes its cascade (for its OWN sample rate) when the
+// generation changes, so a dashboard edit reshapes ALL live streams in realtime,
+// tab-independent, with nothing open.
+struct ZwireEqBand {
+  std::string type;
+  double freq = 0, gain_db = 0, q = 0;
+};
+struct ZwireEqConfig {
+  double preamp_db = 0.0;
+  std::vector<ZwireEqBand> bands;
+  // zdsp channel strip (ported from zdsp-core channel_strip.h) + drive.
+  double gain = 1.0;    // post-EQ linear gain, 0..4
+  double pan = 0.0;     // equal-power pan, -1..1
+  bool mono = false;    // fold L/R to mono after the strip
+  double drive = 0.0;   // tanh soft-clip amount, 0 = bypass
+  // Stereo-linked feed-forward compressor (ratio<=1 => bypass).
+  double comp_thresh_db = 0.0;
+  double comp_ratio = 1.0;
+  double comp_attack_ms = 10.0;
+  double comp_release_ms = 150.0;
+  // Stereo width (M/S): 1 = normal, 0 = mono-collapse, 2 = wide. Applied pre-pan.
+  double width = 1.0;
+  // Brickwall limiter (only active when a "ceiling" directive is present).
+  // Instant-attack, smoothed-release peak limiter; runs dead-last so nothing
+  // after it (pan's sqrt2 boost) can re-introduce an over.
+  bool limit_on = false;
+  double limit_ceiling_db = 0.0;   // dBFS ceiling, -30..0
+  double limit_release_ms = 50.0;
+  // Stereo feedback delay / echo (mix<=0 => bypass).
+  double delay_ms = 0.0;
+  double delay_feedback = 0.0;
+  double delay_mix = 0.0;
+  // Schroeder/Freeverb reverb (mix<=0 => bypass).
+  double reverb_mix = 0.0;
+  double reverb_room = 0.5;
+  double reverb_damp = 0.5;
+  // zdsp-core expansion — dynamics/saturation ------------------------------
+  // Noise gate (thresh very low => bypass): stereo-linked, opens above thresh.
+  double gate_thresh_db = -90.0;   // -90 => effectively open (bypass)
+  double gate_attack_ms = 2.0;
+  double gate_release_ms = 120.0;
+  // Bit-crusher / decimator (bits>=16 && downsample<=1 => bypass).
+  double crush_bits = 16.0;        // quantize depth, 1..16
+  double downsample = 1.0;         // sample&hold rate reduction factor, 1..64
+  // Harmonic exciter (amount<=0 => bypass): high-pass -> soft-clip -> add back.
+  double exciter_amount = 0.0;     // 0..1
+  double exciter_freq = 3000.0;    // high-pass corner, Hz
+  // zdsp-core expansion — spatial ------------------------------------------
+  // Haas widener (ms<=0 => bypass): delays R a few ms for width off mono.
+  double haas_ms = 0.0;            // 0..40
+  // Headphone cross-feed (amount<=0 => bypass): bleed a filtered opposite ch.
+  double crossfeed = 0.0;          // 0..1
+  // zdsp-core expansion — modulation (all mix<=0 => bypass) ------------------
+  // Chorus: LFO-modulated short delay, per-channel, wet/dry blend.
+  double chorus_mix = 0.0;
+  double chorus_rate_hz = 1.5;
+  double chorus_depth_ms = 5.0;
+  // Flanger: LFO-modulated very short delay with feedback.
+  double flanger_mix = 0.0;
+  double flanger_rate_hz = 0.5;
+  double flanger_depth_ms = 2.0;
+  double flanger_feedback = 0.3;
+  // Phaser: cascade of LFO-modulated first-order all-pass stages.
+  double phaser_mix = 0.0;
+  double phaser_rate_hz = 0.5;
+  double phaser_depth = 0.7;       // 0..1 sweep depth
+  // zdsp-core expansion II — saturation/sweep/amplitude --------------------
+  // Waveshaper (amount<=0 => bypass): memoryless nonlinearity, curve by type.
+  double shaper_amount = 0.0;      // 0..1
+  double shaper_type = 0.0;        // 0=arctan(soft) 1=foldback 2=hard-clip
+  // Ring modulator (mix<=0 => bypass): multiply by a sine carrier.
+  double ringmod_mix = 0.0;
+  double ringmod_freq = 500.0;     // carrier Hz
+  // Tremolo (depth<=0 => bypass): LFO amplitude modulation.
+  double tremolo_depth = 0.0;      // 0..1
+  double tremolo_rate_hz = 5.0;
+  // Auto-pan (depth<=0 => bypass): LFO stereo pan.
+  double autopan_depth = 0.0;      // 0..1
+  double autopan_rate_hz = 1.0;
+  // Auto-wah (mix<=0 => bypass): envelope-swept resonant band-pass.
+  double autowah_mix = 0.0;
+  double autowah_sens = 0.5;       // 0..1 envelope sensitivity
+  double autowah_base = 400.0;     // sweep floor Hz
+  uint64_t generation = 0;
+};
+
+namespace {
+
+struct ZwireEqSlotStorage {
+  base::Lock lock;
+  std::shared_ptr<const ZwireEqConfig> cfg;
+};
+ZwireEqSlotStorage& GlobalZwireEqSlot() {
+  static base::NoDestructor<ZwireEqSlotStorage> slot;
+  return *slot;
+}
+std::shared_ptr<const ZwireEqConfig> LoadZwireEqConfig() {
+  ZwireEqSlotStorage& s = GlobalZwireEqSlot();
+  base::AutoLock l(s.lock);
+  return s.cfg;
+}
+std::shared_ptr<const ZwireEqConfig> ParseZwireEqSpec(const std::string& spec) {
+  std::vector<std::string_view> parts = base::SplitStringPiece(
+      spec, ";", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+  if (parts.empty()) {
+    return nullptr;
+  }
+  double preamp_db = 0.0;
+  if (!base::StringToDouble(parts[0], &preamp_db)) {
+    return nullptr;
+  }
+  auto cfg = std::make_shared<ZwireEqConfig>();
+  cfg->preamp_db = preamp_db;
+  for (size_t i = 1; i < parts.size(); ++i) {
+    std::vector<std::string_view> f = base::SplitStringPiece(
+        parts[i], ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+    // Channel-strip directive: "name,value" (2 fields) — zdsp channel_strip.
+    if (f.size() == 2) {
+      double v = 0;
+      if (!base::StringToDouble(f[1], &v)) {
+        continue;
+      }
+      if (f[0] == "gain") {
+        cfg->gain = std::clamp(v, 0.0, 4.0);
+      } else if (f[0] == "pan") {
+        cfg->pan = std::clamp(v, -1.0, 1.0);
+      } else if (f[0] == "mono") {
+        cfg->mono = (v != 0.0);
+      } else if (f[0] == "drive") {
+        cfg->drive = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "thresh") {
+        cfg->comp_thresh_db = std::clamp(v, -60.0, 0.0);
+      } else if (f[0] == "ratio") {
+        cfg->comp_ratio = std::clamp(v, 1.0, 20.0);
+      } else if (f[0] == "attack") {
+        cfg->comp_attack_ms = std::clamp(v, 0.1, 500.0);
+      } else if (f[0] == "release") {
+        cfg->comp_release_ms = std::clamp(v, 1.0, 3000.0);
+      } else if (f[0] == "width") {
+        cfg->width = std::clamp(v, 0.0, 2.0);
+      } else if (f[0] == "ceiling") {
+        cfg->limit_on = true;
+        cfg->limit_ceiling_db = std::clamp(v, -30.0, 0.0);
+      } else if (f[0] == "limrelease") {
+        cfg->limit_release_ms = std::clamp(v, 1.0, 500.0);
+      } else if (f[0] == "delay") {
+        cfg->delay_ms = std::clamp(v, 0.0, 2000.0);
+      } else if (f[0] == "feedback") {
+        cfg->delay_feedback = std::clamp(v, 0.0, 0.95);
+      } else if (f[0] == "delaymix") {
+        cfg->delay_mix = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "reverb") {
+        cfg->reverb_mix = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "room") {
+        cfg->reverb_room = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "damp") {
+        cfg->reverb_damp = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "gate") {
+        cfg->gate_thresh_db = std::clamp(v, -90.0, 0.0);
+      } else if (f[0] == "gateattack") {
+        cfg->gate_attack_ms = std::clamp(v, 0.1, 200.0);
+      } else if (f[0] == "gaterelease") {
+        cfg->gate_release_ms = std::clamp(v, 1.0, 2000.0);
+      } else if (f[0] == "crush") {
+        cfg->crush_bits = std::clamp(v, 1.0, 16.0);
+      } else if (f[0] == "downsample") {
+        cfg->downsample = std::clamp(v, 1.0, 64.0);
+      } else if (f[0] == "exciter") {
+        cfg->exciter_amount = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "exciterfreq") {
+        cfg->exciter_freq = std::clamp(v, 500.0, 16000.0);
+      } else if (f[0] == "haas") {
+        cfg->haas_ms = std::clamp(v, 0.0, 40.0);
+      } else if (f[0] == "crossfeed") {
+        cfg->crossfeed = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "chorus") {
+        cfg->chorus_mix = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "chorusrate") {
+        cfg->chorus_rate_hz = std::clamp(v, 0.05, 10.0);
+      } else if (f[0] == "chorusdepth") {
+        cfg->chorus_depth_ms = std::clamp(v, 0.1, 20.0);
+      } else if (f[0] == "flanger") {
+        cfg->flanger_mix = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "flangerrate") {
+        cfg->flanger_rate_hz = std::clamp(v, 0.05, 10.0);
+      } else if (f[0] == "flangerdepth") {
+        cfg->flanger_depth_ms = std::clamp(v, 0.1, 10.0);
+      } else if (f[0] == "flangerfb") {
+        cfg->flanger_feedback = std::clamp(v, 0.0, 0.95);
+      } else if (f[0] == "phaser") {
+        cfg->phaser_mix = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "phaserrate") {
+        cfg->phaser_rate_hz = std::clamp(v, 0.05, 10.0);
+      } else if (f[0] == "phaserdepth") {
+        cfg->phaser_depth = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "shaper") {
+        cfg->shaper_amount = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "shapertype") {
+        cfg->shaper_type = std::clamp(v, 0.0, 2.0);
+      } else if (f[0] == "ringmod") {
+        cfg->ringmod_mix = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "ringfreq") {
+        cfg->ringmod_freq = std::clamp(v, 20.0, 8000.0);
+      } else if (f[0] == "tremolo") {
+        cfg->tremolo_depth = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "tremrate") {
+        cfg->tremolo_rate_hz = std::clamp(v, 0.05, 20.0);
+      } else if (f[0] == "autopan") {
+        cfg->autopan_depth = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "panrate") {
+        cfg->autopan_rate_hz = std::clamp(v, 0.05, 10.0);
+      } else if (f[0] == "autowah") {
+        cfg->autowah_mix = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "wahsens") {
+        cfg->autowah_sens = std::clamp(v, 0.0, 1.0);
+      } else if (f[0] == "wahbase") {
+        cfg->autowah_base = std::clamp(v, 100.0, 2000.0);
+      }
+      continue;
+    }
+    if (f.size() < 4) {
+      continue;
+    }
+    ZwireEqBand band;
+    band.type = std::string(f[0]);
+    if (band.type != "lowshelf" && band.type != "peaking" &&
+        band.type != "highshelf" && band.type != "lowpass" &&
+        band.type != "highpass" && band.type != "bandpass" &&
+        band.type != "notch" && band.type != "allpass") {
+      continue;
+    }
+    if (!base::StringToDouble(f[1], &band.freq) ||
+        !base::StringToDouble(f[2], &band.gain_db) ||
+        !base::StringToDouble(f[3], &band.q)) {
+      continue;
+    }
+    if (band.freq <= 0 || band.q <= 0) {
+      continue;
+    }
+    cfg->bands.push_back(std::move(band));
+  }
+  static std::atomic<uint64_t> gen{0};
+  cfg->generation = gen.fetch_add(1, std::memory_order_relaxed) + 1;
+  return cfg;
+}
