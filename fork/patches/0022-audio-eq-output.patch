+namespace {
+// Seed the global once from the launch switch/env so the first blocks are shaped
+// before the browser's first live push (the sandbox blocks reading the file in
+// this process).
+bool SeedZwireEqFromLaunchArgs() {
+  std::string s = base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+      "zwire-audio-eq");
+  if (s.empty()) {
+    const char* spec = ::getenv("ZWIRE_AUDIO_EQ");
+    if (spec) {
+      s = spec;
+    }
+  }
+  // Always seed (empty => unity) so the engine is on by default from the first
+  // block, before the browser's first live push.
+  SetZwireEqConfig(s);
+  return true;
+}
+}  // namespace
+
+class ZwireAudioEq {
+ public:
+  ZwireAudioEq(int sample_rate, int channels)
+      : sample_rate_(sample_rate), channels_(channels) {
+    [[maybe_unused]] static const bool seeded = SeedZwireEqFromLaunchArgs();
+  }
+
+  void Process(media::AudioBus* bus) {
+    std::shared_ptr<const ZwireEqConfig> cfg = LoadZwireEqConfig();
+    if (!cfg) {
+      cached_gen_ = 0;
+      return;  // engine explicitly off ("off"/"0")
+    }
+    if (cfg->generation != cached_gen_) {
+      Rebuild(*cfg);
+    }
+    // Always-on: every stream flows through the engine by default (identity when
+    // the chain is unity). Per channel: preamp -> EQ cascade -> gain -> drive.
+    const int channels = bus->channels();
+    const int frames = bus->frames();
+    for (int ch = 0; ch < channels; ++ch) {
+      if (static_cast<size_t>(ch) >= state_.size()) {
+        break;
+      }
+      base::span<float> data = bus->channel(ch);
+      std::vector<BiquadState>& st = state_[ch];
+      for (int i = 0; i < frames; ++i) {
+        double x = static_cast<double>(data[i]) * preamp_;
+        for (size_t b = 0; b < biquads_.size(); ++b) {
+          const Biquad& q = biquads_[b];
+          BiquadState& s = st[b];
+          double y = q.b0 * x + q.b1 * s.x1 + q.b2 * s.x2 - q.a1 * s.y1 -
+                     q.a2 * s.y2;
+          s.x2 = s.x1;
+          s.x1 = x;
+          s.y2 = s.y1;
+          s.y1 = y;
+          x = y;
+        }
+        x *= gain_;
+        if (drive_ > 0.0) {
+          const double k = 1.0 + drive_ * 8.0;  // tanh soft-clip, unity-normalized
+          x = std::tanh(x * k) / std::tanh(k);
+        }
+        if (shaper_active_) {
+          // Memoryless waveshaper: arctan (soft), foldback, or hard-clip.
+          if (shaper_type_ == 0) {
+            const double d = 1.0 + shaper_amt_ * 12.0;
+            x = std::atan(x * d) / std::atan(d);
+          } else if (shaper_type_ == 1) {
+            double t = x * (1.0 + shaper_amt_ * 4.0);
+            while (t > 1.0 || t < -1.0) {
+              t = (t > 1.0) ? 2.0 - t : -2.0 - t;  // reflect at the rails
+            }
+            x = t;
+          } else {
+            x = std::clamp(x * (1.0 + shaper_amt_ * 12.0), -1.0, 1.0);
+          }
+        }
+        if (exciter_active_ && ch < 2) {
+          // High-pass the signal, soft-clip the high band, add harmonics back.
+          BiquadState& hs = exciter_hp_state_[ch];
+          const Biquad& q = exciter_hp_;
+          const double hp = q.b0 * x + q.b1 * hs.x1 + q.b2 * hs.x2 -
+                            q.a1 * hs.y1 - q.a2 * hs.y2;
+          hs.x2 = hs.x1;
+          hs.x1 = x;
+          hs.y2 = hs.y1;
+          hs.y1 = hp;
+          x += std::tanh(hp * 3.0) * exciter_amt_ * 0.5;
+        }
+        if (crush_active_ && ch < 2) {
+          // Bit-depth quantize + sample&hold rate reduction (lo-fi decimator).
+          if (--crush_hold_count_[ch] <= 0) {
+            crush_hold_count_[ch] = downsample_;
+            crush_hold_val_[ch] = static_cast<float>(
+                std::round(x / crush_step_) * crush_step_);
+          }
+          x = crush_hold_val_[ch];
+        }
+        data[i] = static_cast<float>(x);
+      }
+    }
+    // Noise gate (zdsp-core dynamics): stereo-linked peak detector; opens toward
+    // unity above the threshold, ducks toward silence below it (attack/release
+    // smoothed). Runs before the compressor so it gates the raw level.
+    if (gate_active_ && channels >= 1) {
+      base::span<float> l = bus->channel(0);
+      base::span<float> r = channels >= 2 ? bus->channel(1) : bus->channel(0);
+      for (int i = 0; i < frames; ++i) {
+        const double peak = std::max(std::fabs(static_cast<double>(l[i])),
+                                     std::fabs(static_cast<double>(r[i])));
+        const double target = peak >= gate_thresh_lin_ ? 1.0 : 0.0;
+        const double coeff =
+            (target > gate_env_) ? gate_attack_coeff_ : gate_release_coeff_;
+        gate_env_ = coeff * gate_env_ + (1.0 - coeff) * target;
+        l[i] = static_cast<float>(l[i] * gate_env_);
+        if (channels >= 2) {
+          r[i] = static_cast<float>(r[i] * gate_env_);
+        }
+      }
+    }
+    // Stereo-linked feed-forward compressor (ratio<=1 => bypass). Peak detector
+    // on max(|L|,|R|); attack/release smoothing on the linear gain.
+    if (comp_ratio_ > 1.0 && channels >= 1) {
+      base::span<float> l = bus->channel(0);
+      base::span<float> r = channels >= 2 ? bus->channel(1) : bus->channel(0);
+      for (int i = 0; i < frames; ++i) {
+        const double peak = std::max(std::fabs(static_cast<double>(l[i])),
+                                     std::fabs(static_cast<double>(r[i])));
+        const double level_db = 20.0 * std::log10(std::max(peak, 1e-9));
+        const double over = level_db - comp_thresh_db_;
+        double target_gain = 1.0;
+        if (over > 0.0) {
+          const double gr_db = over * (1.0 - 1.0 / comp_ratio_);
+          target_gain = std::pow(10.0, -gr_db / 20.0);
+        }
+        const double coeff =
+            (target_gain < comp_env_) ? comp_attack_coeff_ : comp_release_coeff_;
+        comp_env_ = coeff * comp_env_ + (1.0 - coeff) * target_gain;
+        l[i] = static_cast<float>(l[i] * comp_env_);
+        if (channels >= 2) {
+          r[i] = static_cast<float>(r[i] * comp_env_);
+        }
+      }
+    }
+    // Auto-wah (zdsp-core): a resonant band-pass whose center frequency tracks
+    // the signal envelope. Coeffs rebuilt once per block from the running
+    // envelope (cheap); the envelope keeps following per-sample for the next.
+    if (autowah_active_ && channels >= 1) {
+      double fc = autowah_base_ +
+                  autowah_sens_ * 3500.0 * std::min(1.0, wah_env_ * 4.0);
+      fc = std::clamp(fc, 60.0, sample_rate_ * 0.45);
+      const double w0 = 2.0 * M_PI * fc / sample_rate_;
+      const double cw = std::cos(w0), sw = std::sin(w0);
+      const double alpha = sw / (2.0 * 3.0);  // Q = 3
+      const double a0 = 1 + alpha;
+      const Biquad bp{alpha / a0, 0.0, -alpha / a0, -2 * cw / a0,
+                      (1 - alpha) / a0};
+      const int nc = std::min(channels, 2);
+      base::span<float> l = bus->channel(0);
+      base::span<float> r = channels >= 2 ? bus->channel(1) : bus->channel(0);
+      for (int i = 0; i < frames; ++i) {
+        const double peak = std::max(std::fabs(static_cast<double>(l[i])),
+                                     std::fabs(static_cast<double>(r[i])));
+        const double coeff = peak > wah_env_ ? wah_atk_ : wah_rel_;
+        wah_env_ = coeff * wah_env_ + (1.0 - coeff) * peak;
+        for (int ch = 0; ch < nc; ++ch) {
+          base::span<float> d = ch == 0 ? l : r;
+          BiquadState& s = wah_state_[ch];
+          const double in = d[i];
+          const double y = bp.b0 * in + bp.b1 * s.x1 + bp.b2 * s.x2 -
+                           bp.a1 * s.y1 - bp.a2 * s.y2;
+          s.x2 = s.x1;
+          s.x1 = in;
+          s.y2 = s.y1;
+          s.y1 = y;
+          d[i] = static_cast<float>(in * (1.0 - autowah_mix_) + y * autowah_mix_);
+        }
+      }
+    }
+    // Modulation (zdsp-core): chorus/flanger (LFO-swept fractional delay) then
+    // phaser (LFO-swept all-pass cascade). One LFO phase per effect, advanced
+    // once per frame so both channels share a coherent sweep.
+    if (chorus_active_ || flanger_active_ || phaser_active_) {
+      const int nc = std::min(channels, 2);
+      base::span<float> ch0 = bus->channel(0);
+      base::span<float> ch1 = channels >= 2 ? bus->channel(1) : bus->channel(0);
+      for (int i = 0; i < frames; ++i) {
+        const double cl = 0.5 - 0.5 * std::cos(2.0 * M_PI * chorus_phase_);
+        const double fl = 0.5 - 0.5 * std::cos(2.0 * M_PI * flanger_phase_);
+        const double pl = 0.5 - 0.5 * std::cos(2.0 * M_PI * phaser_phase_);
+        const float pg = static_cast<float>(0.1 + phaser_depth_ * 0.8 * pl);
+        for (int ch = 0; ch < nc; ++ch) {
+          base::span<float> d = ch == 0 ? ch0 : ch1;
+          float x = d[i];
+          if (chorus_active_) {
+            x = chorus_[ch].Process(x, chorus_base_s_ + cl * chorus_depth_s_);
+          }
+          if (flanger_active_) {
+            x = flanger_[ch].Process(x, flanger_base_s_ + fl * flanger_depth_s_);
+          }
+          if (phaser_active_) {
+            float wet = x;
+            for (int s = 0; s < kPhaserStages; ++s) {
+              wet = phaser_stages_[ch][s].Process(wet, pg);
+            }
+            x = x * (1.f - phaser_mix_) + wet * phaser_mix_;
+          }
+          d[i] = x;
+        }
+        chorus_phase_ += chorus_rate_;
+        if (chorus_phase_ >= 1.0) chorus_phase_ -= 1.0;
+        flanger_phase_ += flanger_rate_;
+        if (flanger_phase_ >= 1.0) flanger_phase_ -= 1.0;
+        phaser_phase_ += phaser_rate_;
+        if (phaser_phase_ >= 1.0) phaser_phase_ -= 1.0;
+      }
+    }
+    // Ring modulator (zdsp-core): multiply by a sine carrier (metallic/clangorous
+    // wet blended with dry). One carrier phase advanced per frame.
+    if (ringmod_active_) {
+      const int nc = std::min(channels, 2);
+      base::span<float> ch0 = bus->channel(0);
+      base::span<float> ch1 = channels >= 2 ? bus->channel(1) : bus->channel(0);
+      for (int i = 0; i < frames; ++i) {
+        const float c = static_cast<float>(std::sin(2.0 * M_PI * ring_phase_));
+        for (int ch = 0; ch < nc; ++ch) {
+          base::span<float> d = ch == 0 ? ch0 : ch1;
+          d[i] = d[i] * (1.f - ring_mix_) + d[i] * c * ring_mix_;
+        }
+        ring_phase_ += ring_rate_;
+        if (ring_phase_ >= 1.0) ring_phase_ -= 1.0;
+      }
+    }
+    // Tremolo (zdsp-core): LFO amplitude modulation, stereo-linked so the image
+    // stays put (auto-pan handles moving it). Sine LFO, unity at the crest.
+    if (tremolo_active_) {
+      const int nc = std::min(channels, 2);
+      base::span<float> ch0 = bus->channel(0);
+      base::span<float> ch1 = channels >= 2 ? bus->channel(1) : bus->channel(0);
+      for (int i = 0; i < frames; ++i) {
+        const float g = static_cast<float>(
+            1.0 - tremolo_depth_ * (0.5 - 0.5 * std::cos(2.0 * M_PI * trem_phase_)));
+        for (int ch = 0; ch < nc; ++ch) {
+          base::span<float> d = ch == 0 ? ch0 : ch1;
+          d[i] *= g;
+        }
+        trem_phase_ += trem_rate_;
+        if (trem_phase_ >= 1.0) trem_phase_ -= 1.0;
+      }
+    }
+    // Time FX: stereo feedback delay/echo then Schroeder reverb, each an
+    // independent per-channel path (bypassed unless enabled). State + buffers are
+    // owned per stream, so every stream gets its own echo/tail.
+    if (delay_active_ || reverb_active_) {
+      const int nc = std::min(channels, 2);
+      for (int ch = 0; ch < nc; ++ch) {
+        base::span<float> d = bus->channel(ch);
+        for (int i = 0; i < frames; ++i) {
+          float x = d[i];
+          if (delay_active_) {
+            x = delay_[ch].Process(x);
+          }
+          if (reverb_active_) {
+            x = reverb_[ch].Process(x);
+          }
+          d[i] = x;
+        }
+      }
+    }
+    // Haas widener (zdsp-core spatial): delay R by a few ms so a mono/centered
+    // source gains stereo width (classic precedence-effect widener).
+    if (haas_active_ && channels >= 2) {
+      base::span<float> r = bus->channel(1);
+      for (int i = 0; i < frames; ++i) {
+        const float d = haas_buf_[haas_pos_];
+        haas_buf_[haas_pos_] = r[i];
+        r[i] = d;
+        if (++haas_pos_ >= haas_buf_.size()) {
+          haas_pos_ = 0;
+        }
+      }
+    }
+    // Headphone cross-feed (zdsp-core spatial): bleed a one-pole-lowpassed copy
+    // of each channel into the other to relax hard-panned stereo on headphones.
+    if (crossfeed_active_ && channels >= 2) {
+      base::span<float> l = bus->channel(0);
+      base::span<float> r = bus->channel(1);
+      const float a = static_cast<float>(crossfeed_amt_);
+      const float norm = 1.f / (1.f + a);
+      for (int i = 0; i < frames; ++i) {
+        cf_lp_[0] += cf_coeff_ * (r[i] - cf_lp_[0]);
+        cf_lp_[1] += cf_coeff_ * (l[i] - cf_lp_[1]);
+        const float nl = (l[i] + a * cf_lp_[0]) * norm;
+        const float nr = (r[i] + a * cf_lp_[1]) * norm;
+        l[i] = nl;
+        r[i] = nr;
+      }
+    }
+    // Auto-pan (zdsp-core spatial): equal-power pan swept by a sine LFO, before
+    // the static width/pan strip so a moving image still gets width applied.
+    if (autopan_active_ && channels >= 2) {
+      base::span<float> l = bus->channel(0);
+      base::span<float> r = bus->channel(1);
+      for (int i = 0; i < frames; ++i) {
+        const double p = autopan_depth_ * std::sin(2.0 * M_PI * autopan_phase_);
+        const double ang = (p + 1.0) * M_PI / 4.0;
+        l[i] = static_cast<float>(l[i] * std::cos(ang) * M_SQRT2);
+        r[i] = static_cast<float>(r[i] * std::sin(ang) * M_SQRT2);
+        autopan_phase_ += autopan_rate_;
+        if (autopan_phase_ >= 1.0) autopan_phase_ -= 1.0;
+      }
+    }
+    // Stereo strip (zdsp channel_strip.h): M/S width, then mono fold, else
+    // equal-power pan with a unity-gain center (sqrt(2) normalized so pan=0 is
+    // transparent, not -3 dB).
+    if (channels >= 2) {
+      base::span<float> l = bus->channel(0);
+      base::span<float> r = bus->channel(1);
+      if (!mono_ && width_ != 1.0) {
+        const float w = static_cast<float>(width_);
+        for (int i = 0; i < frames; ++i) {
+          const float mid = 0.5f * (l[i] + r[i]);
+          const float side = 0.5f * (l[i] - r[i]) * w;
+          l[i] = mid + side;
+          r[i] = mid - side;
+        }
+      }
+      if (mono_) {
+        for (int i = 0; i < frames; ++i) {
+          const float m = 0.5f * (l[i] + r[i]);
+          l[i] = m;
+          r[i] = m;
+        }
+      } else if (pan_ != 0.0) {
+        const double ang = (pan_ + 1.0) * M_PI / 4.0;
+        const float cl = static_cast<float>(std::cos(ang) * M_SQRT2);
+        const float cr = static_cast<float>(std::sin(ang) * M_SQRT2);
+        for (int i = 0; i < frames; ++i) {
+          l[i] *= cl;
+          r[i] *= cr;
+        }
+      }
+    }
+    // Brickwall limiter (last): stereo-linked peak detector on max(|L|,|R|),
+    // instant attack (never lets a sample exceed the ceiling), smoothed release.
+    if (limit_active_ && channels >= 1) {
+      base::span<float> l = bus->channel(0);
+      base::span<float> r = channels >= 2 ? bus->channel(1) : bus->channel(0);
+      for (int i = 0; i < frames; ++i) {
+        const double peak = std::max(std::fabs(static_cast<double>(l[i])),
+                                     std::fabs(static_cast<double>(r[i])));
+        double target = 1.0;
+        if (peak > limit_ceiling_lin_ && peak > 1e-9) {
+          target = limit_ceiling_lin_ / peak;
+        }
+        if (target < limit_env_) {
+          limit_env_ = target;   // attack: instantaneous
+        } else {
+          limit_env_ = limit_release_coeff_ * limit_env_ +
+                       (1.0 - limit_release_coeff_) * target;
+        }
+        l[i] = static_cast<float>(l[i] * limit_env_);
+        if (channels >= 2) {
+          r[i] = static_cast<float>(r[i] * limit_env_);
+        }
+      }
+    }
+  }
+
+ private:
+  struct Biquad {
+    double b0, b1, b2, a1, a2;
+  };
+  struct BiquadState {
+    double x1 = 0, x2 = 0, y1 = 0, y2 = 0;
+  };
+  // Mono feedback delay line (one per channel). Wet/dry blend so mix=0 is a
+  // no-op and the dry stays unity. Buffer sized to the exact delay time.
+  struct DelayLine {
+    std::vector<float> buf;
+    size_t pos = 0;
+    float fb = 0.f, mix = 0.f;
+    void Init(int samples, double feedback, double m) {
+      buf.assign(static_cast<size_t>(std::max(1, samples)), 0.f);
+      pos = 0;
+      fb = static_cast<float>(feedback);
+      mix = static_cast<float>(m);
+    }
+    float Process(float in) {
+      float d = buf[pos];
+      buf[pos] = in + d * fb;
+      if (++pos >= buf.size()) {
+        pos = 0;
+      }
+      return in * (1.f - mix) + d * mix;
+    }
+  };
+  // Reduced Freeverb (4 combs + 2 series all-passes per channel). Freeverb comb
+  // tunings + damping/roomsize/fixedgain constants; the right channel offsets its
+  // buffer sizes by `spread` for stereo decorrelation. Public-domain algorithm.
+  struct Reverb {
+    static constexpr int kCombs = 4;
+    static constexpr int kAll = 2;
+    std::vector<float> comb[kCombs];
+    size_t comb_pos[kCombs] = {};
+    float comb_store[kCombs] = {};
+    std::vector<float> allp[kAll];
+    size_t all_pos[kAll] = {};
+    float feedback = 0.f, damp1 = 0.f, damp2 = 0.f, mix = 0.f, gain = 0.015f;
+    void Init(int sr, double room, double damp, double m, int spread) {
+      static const int ct[kCombs] = {1116, 1188, 1277, 1356};
+      static const int at[kAll] = {556, 441};
+      const double scale = sr / 44100.0;
+      for (int i = 0; i < kCombs; ++i) {
+        comb[i].assign(
+            static_cast<size_t>(std::max(1, static_cast<int>(ct[i] * scale) + spread)),
+            0.f);
+        comb_pos[i] = 0;
+        comb_store[i] = 0.f;
+      }
+      for (int i = 0; i < kAll; ++i) {
+        allp[i].assign(
+            static_cast<size_t>(std::max(1, static_cast<int>(at[i] * scale) + spread)),
+            0.f);
+        all_pos[i] = 0;
+      }
+      feedback = static_cast<float>(room * 0.28 + 0.7);   // Freeverb scaleroom/offsetroom
+      damp1 = static_cast<float>(damp * 0.4);             // Freeverb scaledamp
+      damp2 = 1.f - damp1;
+      mix = static_cast<float>(m);
+    }
+    float Process(float in) {
+      const float input = in * gain;
+      float out = 0.f;
+      for (int i = 0; i < kCombs; ++i) {
+        const float y = comb[i][comb_pos[i]];
+        comb_store[i] = y * damp2 + comb_store[i] * damp1;
+        comb[i][comb_pos[i]] = input + comb_store[i] * feedback;
+        if (++comb_pos[i] >= comb[i].size()) {
+          comb_pos[i] = 0;
+        }
+        out += y;
+      }
+      for (int i = 0; i < kAll; ++i) {
+        const float bufout = allp[i][all_pos[i]];
+        const float y = -out + bufout;
+        allp[i][all_pos[i]] = out + bufout * 0.5f;   // Freeverb allpass feedback
+        if (++all_pos[i] >= allp[i].size()) {
+          all_pos[i] = 0;
+        }
+        out = y;
+      }
+      return in * (1.f - mix) + out * mix;
+    }
+  };
+  // Modulated fractional-delay line (chorus/flanger). A time-varying read tap is
+  // linearly interpolated; `fb` feeds output back for flanging (0 for chorus).
+  struct ModDelay {
+    std::vector<float> buf;
+    size_t pos = 0;
+    float fb = 0.f, mix = 0.f;
+    void Init(int maxlen, double feedback, double m) {
+      buf.assign(static_cast<size_t>(std::max(4, maxlen)), 0.f);
+      pos = 0;
+      fb = static_cast<float>(feedback);
+      mix = static_cast<float>(m);
+    }
+    float Process(float in, double delay_samples) {
+      const double n = static_cast<double>(buf.size());
+      double rp = static_cast<double>(pos) - delay_samples;
+      while (rp < 0) rp += n;
+      const size_t i0 = static_cast<size_t>(rp) % buf.size();
+      const size_t i1 = (i0 + 1) % buf.size();
+      const double frac = rp - std::floor(rp);
+      const float d = static_cast<float>((1.0 - frac) * buf[i0] + frac * buf[i1]);
+      buf[pos] = in + d * fb;
+      if (++pos >= buf.size()) {
+        pos = 0;
+      }
+      return in * (1.f - mix) + d * mix;
+    }
+  };
+  // First-order all-pass stage (phaser). Transposed direct form; `g` is the
+  // LFO-swept coefficient. Cascading N stages makes N spectral notches sweep.
+  struct AllpassStage {
+    float x1 = 0.f, y1 = 0.f;
+    float Process(float in, float g) {
+      const float y = -g * in + x1 + g * y1;
+      x1 = in;
+      y1 = y;
+      return y;
+    }
+  };
+
+  // Recompute this stream's biquad cascade for its own sample rate from the new
+  // config snapshot; keep it stateful across the swap by resizing filter memory.
+  void Rebuild(const ZwireEqConfig& cfg) {
+    preamp_ = std::pow(10.0, cfg.preamp_db / 20.0);
+    gain_ = cfg.gain;
+    pan_ = cfg.pan;
+    mono_ = cfg.mono;
+    drive_ = cfg.drive;
+    comp_thresh_db_ = cfg.comp_thresh_db;
+    comp_ratio_ = cfg.comp_ratio;
+    comp_attack_coeff_ = std::exp(
+        -1.0 / std::max(1.0, cfg.comp_attack_ms * 0.001 * sample_rate_));
+    comp_release_coeff_ = std::exp(
+        -1.0 / std::max(1.0, cfg.comp_release_ms * 0.001 * sample_rate_));
+    width_ = cfg.width;
+    // Brickwall limiter.
+    limit_active_ = cfg.limit_on;
+    limit_ceiling_lin_ = std::pow(10.0, cfg.limit_ceiling_db / 20.0);
+    limit_release_coeff_ = std::exp(
+        -1.0 / std::max(1.0, cfg.limit_release_ms * 0.001 * sample_rate_));
+    limit_env_ = 1.0;
+    // Stereo delay/echo: (re)size the ring to the exact delay time; buffers are
+    // only allocated while enabled so a bypassed engine carries no delay memory.
+    delay_active_ = cfg.delay_mix > 1e-4 && cfg.delay_ms > 0.1;
+    if (delay_active_) {
+      const int n = std::max(
+          1, static_cast<int>(std::lround(cfg.delay_ms * 0.001 * sample_rate_)));
+      for (int ch = 0; ch < 2; ++ch) {
+        delay_[ch].Init(n, cfg.delay_feedback, cfg.delay_mix);
+      }
+    }
+    // Schroeder reverb: right channel offset by the Freeverb stereospread (23).
+    reverb_active_ = cfg.reverb_mix > 1e-4;
+    if (reverb_active_) {
+      reverb_[0].Init(sample_rate_, cfg.reverb_room, cfg.reverb_damp,
+                      cfg.reverb_mix, 0);
+      reverb_[1].Init(sample_rate_, cfg.reverb_room, cfg.reverb_damp,
+                      cfg.reverb_mix, 23);
+    }
+    // Noise gate.
+    gate_active_ = cfg.gate_thresh_db > -89.5;
+    gate_thresh_lin_ = std::pow(10.0, cfg.gate_thresh_db / 20.0);
+    gate_attack_coeff_ = std::exp(
+        -1.0 / std::max(1.0, cfg.gate_attack_ms * 0.001 * sample_rate_));
+    gate_release_coeff_ = std::exp(
+        -1.0 / std::max(1.0, cfg.gate_release_ms * 0.001 * sample_rate_));
+    // Bit-crusher / decimator: active when reducing depth or rate.
+    downsample_ = std::max(1, static_cast<int>(std::lround(cfg.downsample)));
+    crush_active_ = cfg.crush_bits < 15.5 || downsample_ > 1;
+    crush_step_ = std::pow(2.0, 1.0 - cfg.crush_bits);  // signed quantum
+    for (int ch = 0; ch < 2; ++ch) {
+      crush_hold_count_[ch] = 0;
+      crush_hold_val_[ch] = 0.f;
+    }
+    // Harmonic exciter: RBJ high-pass whose highs are soft-clipped + mixed back.
+    exciter_active_ = cfg.exciter_amount > 1e-4;
+    exciter_amt_ = cfg.exciter_amount;
+    if (exciter_active_) {
+      const double w0 = 2.0 * M_PI * cfg.exciter_freq / sample_rate_;
+      const double cw = std::cos(w0), sw = std::sin(w0);
+      const double alpha = sw / (2.0 * 0.707);
+      const double a0 = 1 + alpha;
+      exciter_hp_ = Biquad{(1 + cw) / 2 / a0, -(1 + cw) / a0, (1 + cw) / 2 / a0,
+                           -2 * cw / a0, (1 - alpha) / a0};
+      for (int ch = 0; ch < 2; ++ch) {
+        exciter_hp_state_[ch] = BiquadState{};
+      }
+    }
+    // Haas widener: R delayed by haas_ms (buffer sized to the exact delay).
+    haas_active_ = cfg.haas_ms > 1e-3;
+    if (haas_active_) {
+      const int n = std::max(
+          1, static_cast<int>(std::lround(cfg.haas_ms * 0.001 * sample_rate_)));
+      haas_buf_.assign(static_cast<size_t>(n), 0.f);
+      haas_pos_ = 0;
+    }
+    // Headphone cross-feed: one-pole lowpass (~700 Hz) on the bled channel.
+    crossfeed_active_ = cfg.crossfeed > 1e-4;
+    crossfeed_amt_ = cfg.crossfeed;
+    cf_coeff_ =
+        static_cast<float>(1.0 - std::exp(-2.0 * M_PI * 700.0 / sample_rate_));
+    cf_lp_[0] = cf_lp_[1] = 0.f;
+    // Chorus / flanger: (re)size the modulated delay lines to base+depth.
+    chorus_active_ = cfg.chorus_mix > 1e-4;
+    if (chorus_active_) {
+      chorus_rate_ = cfg.chorus_rate_hz / sample_rate_;
+      chorus_base_s_ = 0.010 * sample_rate_;
+      chorus_depth_s_ = cfg.chorus_depth_ms * 0.001 * sample_rate_;
+      const int maxd =
+          static_cast<int>(std::ceil(chorus_base_s_ + chorus_depth_s_)) + 4;
+      for (int ch = 0; ch < 2; ++ch) {
+        chorus_[ch].Init(maxd, 0.0, cfg.chorus_mix);
+      }
+    }
+    flanger_active_ = cfg.flanger_mix > 1e-4;
+    if (flanger_active_) {
+      flanger_rate_ = cfg.flanger_rate_hz / sample_rate_;
+      flanger_base_s_ = 0.001 * sample_rate_;
+      flanger_depth_s_ = cfg.flanger_depth_ms * 0.001 * sample_rate_;
+      const int maxd =
+          static_cast<int>(std::ceil(flanger_base_s_ + flanger_depth_s_)) + 4;
+      for (int ch = 0; ch < 2; ++ch) {
+        flanger_[ch].Init(maxd, cfg.flanger_feedback, cfg.flanger_mix);
+      }
+    }
+    // Phaser: LFO-swept all-pass cascade (state reset on (re)engage).
+    phaser_active_ = cfg.phaser_mix > 1e-4;
+    phaser_mix_ = static_cast<float>(cfg.phaser_mix);
+    phaser_rate_ = cfg.phaser_rate_hz / sample_rate_;
+    phaser_depth_ = cfg.phaser_depth;
+    if (phaser_active_) {
+      for (int ch = 0; ch < 2; ++ch) {
+        for (int s = 0; s < kPhaserStages; ++s) {
+          phaser_stages_[ch][s] = AllpassStage{};
+        }
+      }
+    }
+    // Waveshaper (memoryless).
+    shaper_active_ = cfg.shaper_amount > 1e-4;
+    shaper_amt_ = cfg.shaper_amount;
+    shaper_type_ = static_cast<int>(std::lround(cfg.shaper_type));
+    // Ring modulator.
+    ringmod_active_ = cfg.ringmod_mix > 1e-4;
+    ring_mix_ = static_cast<float>(cfg.ringmod_mix);
+    ring_rate_ = cfg.ringmod_freq / sample_rate_;
+    // Tremolo.
+    tremolo_active_ = cfg.tremolo_depth > 1e-4;
+    tremolo_depth_ = cfg.tremolo_depth;
+    trem_rate_ = cfg.tremolo_rate_hz / sample_rate_;
+    // Auto-pan.
+    autopan_active_ = cfg.autopan_depth > 1e-4;
+    autopan_depth_ = cfg.autopan_depth;
+    autopan_rate_ = cfg.autopan_rate_hz / sample_rate_;
+    // Auto-wah: envelope-swept band-pass (attack/release on the follower).
+    autowah_active_ = cfg.autowah_mix > 1e-4;
+    autowah_mix_ = cfg.autowah_mix;
+    autowah_base_ = cfg.autowah_base;
+    autowah_sens_ = cfg.autowah_sens;
+    wah_atk_ = std::exp(-1.0 / std::max(1.0, 0.005 * sample_rate_));   // ~5ms
+    wah_rel_ = std::exp(-1.0 / std::max(1.0, 0.080 * sample_rate_));   // ~80ms
+    if (autowah_active_) {
+      for (int ch = 0; ch < 2; ++ch) {
+        wah_state_[ch] = BiquadState{};
+      }
+    }
+    biquads_.clear();
+    for (const ZwireEqBand& band : cfg.bands) {
+      AddBand(band);
+    }
+    state_.assign(static_cast<size_t>(channels_),
+                  std::vector<BiquadState>(biquads_.size()));
+    cached_gen_ = cfg.generation;
+    VLOG(1) << "zwire-eq-rebuild: gen=" << cfg.generation
+            << " preamp_db=" << cfg.preamp_db << " bands=" << cfg.bands.size()
+            << " gain=" << gain_ << " pan=" << pan_ << " mono=" << mono_
+            << " drive=" << drive_ << " width=" << width_
+            << " limit=" << limit_active_ << " delay=" << delay_active_
+            << " reverb=" << reverb_active_ << " sr=" << sample_rate_;
+  }
+
+  void AddBand(const ZwireEqBand& band) {
+    if (band.freq <= 0 || band.q <= 0 || band.freq >= sample_rate_ / 2.0) {
+      return;
+    }
+    const double A = std::pow(10.0, band.gain_db / 40.0);
+    const double w0 = 2.0 * M_PI * band.freq / sample_rate_;
+    const double cw = std::cos(w0);
+    const double sw = std::sin(w0);
+    const double alpha = sw / (2.0 * band.q);
+    double b0, b1, b2, a0, a1, a2;
+    if (band.type == "peaking") {
+      b0 = 1 + alpha * A;
+      b1 = -2 * cw;
+      b2 = 1 - alpha * A;
+      a0 = 1 + alpha / A;
+      a1 = -2 * cw;
+      a2 = 1 - alpha / A;
+    } else if (band.type == "lowshelf") {
+      const double s = 2 * std::sqrt(A) * alpha;
+      b0 = A * ((A + 1) - (A - 1) * cw + s);
+      b1 = 2 * A * ((A - 1) - (A + 1) * cw);
+      b2 = A * ((A + 1) - (A - 1) * cw - s);
+      a0 = (A + 1) + (A - 1) * cw + s;
+      a1 = -2 * ((A - 1) + (A + 1) * cw);
+      a2 = (A + 1) + (A - 1) * cw - s;
+    } else if (band.type == "highshelf") {
+      const double s = 2 * std::sqrt(A) * alpha;
+      b0 = A * ((A + 1) + (A - 1) * cw + s);
+      b1 = -2 * A * ((A - 1) + (A + 1) * cw);
+      b2 = A * ((A + 1) + (A - 1) * cw - s);
+      a0 = (A + 1) - (A - 1) * cw + s;
+      a1 = 2 * ((A - 1) - (A + 1) * cw);
+      a2 = (A + 1) - (A - 1) * cw - s;
+    } else if (band.type == "lowpass") {
+      b0 = (1 - cw) / 2;
+      b1 = 1 - cw;
+      b2 = (1 - cw) / 2;
+      a0 = 1 + alpha;
+      a1 = -2 * cw;
+      a2 = 1 - alpha;
+    } else if (band.type == "highpass") {
+      b0 = (1 + cw) / 2;
+      b1 = -(1 + cw);
+      b2 = (1 + cw) / 2;
+      a0 = 1 + alpha;
+      a1 = -2 * cw;
+      a2 = 1 - alpha;
+    } else if (band.type == "bandpass") {  // 0 dB peak gain (CPG)
+      b0 = alpha;
+      b1 = 0;
+      b2 = -alpha;
+      a0 = 1 + alpha;
+      a1 = -2 * cw;
+      a2 = 1 - alpha;
+    } else if (band.type == "notch") {
+      b0 = 1;
+      b1 = -2 * cw;
+      b2 = 1;
+      a0 = 1 + alpha;
+      a1 = -2 * cw;
+      a2 = 1 - alpha;
+    } else if (band.type == "allpass") {
+      b0 = 1 - alpha;
+      b1 = -2 * cw;
+      b2 = 1 + alpha;
+      a0 = 1 + alpha;
+      a1 = -2 * cw;
+      a2 = 1 - alpha;
+    } else {
+      return;
+    }
+    if (a0 == 0) {
+      return;
+    }
+    biquads_.push_back(Biquad{b0 / a0, b1 / a0, b2 / a0, a1 / a0, a2 / a0});
+  }
+
+  const int sample_rate_;
+  const int channels_;
+  uint64_t cached_gen_ = 0;
+  double preamp_ = 1.0;
+  double gain_ = 1.0;
+  double pan_ = 0.0;
+  bool mono_ = false;
+  double drive_ = 0.0;
+  double comp_thresh_db_ = 0.0;
+  double comp_ratio_ = 1.0;
+  double comp_attack_coeff_ = 0.0;
+  double comp_release_coeff_ = 0.0;
+  double comp_env_ = 1.0;
+  double width_ = 1.0;
+  bool limit_active_ = false;
+  double limit_ceiling_lin_ = 1.0;
+  double limit_release_coeff_ = 0.0;
+  double limit_env_ = 1.0;
+  bool delay_active_ = false;
+  bool reverb_active_ = false;
+  DelayLine delay_[2];
+  Reverb reverb_[2];
+  // zdsp-core expansion — dynamics/saturation.
+  bool gate_active_ = false;
+  double gate_thresh_lin_ = 0.0;
+  double gate_attack_coeff_ = 0.0, gate_release_coeff_ = 0.0;
+  double gate_env_ = 1.0;
+  bool crush_active_ = false;
+  double crush_step_ = 0.0;
+  int downsample_ = 1;
+  int crush_hold_count_[2] = {0, 0};
+  float crush_hold_val_[2] = {0.f, 0.f};
+  bool exciter_active_ = false;
+  double exciter_amt_ = 0.0;
+  Biquad exciter_hp_ = {1, 0, 0, 0, 0};
+  BiquadState exciter_hp_state_[2];
+  // zdsp-core expansion — spatial.
+  bool haas_active_ = false;
+  std::vector<float> haas_buf_;
+  size_t haas_pos_ = 0;
+  bool crossfeed_active_ = false;
+  double crossfeed_amt_ = 0.0;
+  float cf_coeff_ = 0.f;
+  float cf_lp_[2] = {0.f, 0.f};
+  // zdsp-core expansion — modulation.
+  static constexpr int kPhaserStages = 4;
+  bool chorus_active_ = false, flanger_active_ = false, phaser_active_ = false;
+  ModDelay chorus_[2], flanger_[2];
+  double chorus_phase_ = 0.0, chorus_rate_ = 0.0;
+  double chorus_base_s_ = 0.0, chorus_depth_s_ = 0.0;
+  double flanger_phase_ = 0.0, flanger_rate_ = 0.0;
+  double flanger_base_s_ = 0.0, flanger_depth_s_ = 0.0;
+  double phaser_phase_ = 0.0, phaser_rate_ = 0.0, phaser_depth_ = 0.0;
+  float phaser_mix_ = 0.f;
+  AllpassStage phaser_stages_[2][kPhaserStages];
+  // zdsp-core expansion II — saturation/sweep/amplitude.
+  bool shaper_active_ = false;
+  double shaper_amt_ = 0.0;
+  int shaper_type_ = 0;
+  bool ringmod_active_ = false;
+  float ring_mix_ = 0.f;
+  double ring_phase_ = 0.0, ring_rate_ = 0.0;
+  bool tremolo_active_ = false;
+  double tremolo_depth_ = 0.0;
+  double trem_phase_ = 0.0, trem_rate_ = 0.0;
+  bool autopan_active_ = false;
+  double autopan_depth_ = 0.0;
+  double autopan_phase_ = 0.0, autopan_rate_ = 0.0;
+  bool autowah_active_ = false;
+  double autowah_mix_ = 0.0, autowah_base_ = 400.0, autowah_sens_ = 0.5;
+  double wah_env_ = 0.0, wah_atk_ = 0.0, wah_rel_ = 0.0;
+  BiquadState wah_state_[2];
+  std::vector<Biquad> biquads_;
+  std::vector<std::vector<BiquadState>> state_;
+};
