diff --git a/front_end/design_system_tokens.css b/front_end/design_system_tokens.css
index de3f89a652..0f3be3fa00 100644
--- a/front_end/design_system_tokens.css
+++ b/front_end/design_system_tokens.css
@@ -1059,3 +1059,57 @@
   --ref-palette-indigo99: rgb(255 251 255 / 100%);
   --ref-palette-indigo100: rgb(255 255 255 / 100%);
 }
+
+/* zwire HUD: force the strykelang cyberpunk palette onto DevTools, overriding
+ * the default grey dark theme. Appended last so these win the cascade. */
+/* Scheme key-colors — active only when a zwire scheme is chosen in the
+ * DevTools Theme dropdown (ThemeSupport sets data-zbhud on <html>). Default
+ * (cyberpunk) key-colors; only ~9 vars change per scheme. Without data-zbhud,
+ * DevTools' normal Light/Dark/Auto themes are untouched. */
+:root[data-zbhud] {
+  --zb-bg:#05050a; --zb-bg2:#0a0a14; --zb-card:#0d0d1a; --zb-hi:#12122a;
+  --zb-text:#e0f0ff; --zb-dim:#7a8ba8; --zb-accent:#ff2a6d; --zb-cyan:#05d9e8; --zb-border:#1a1a3e;
+}
+:root[data-zbhud="midnight"]{--zb-bg:#020617;--zb-bg2:#0f172a;--zb-card:#1e293b;--zb-hi:#334155;--zb-text:#e2e8f0;--zb-dim:#94a3b8;--zb-accent:#7c3aed;--zb-cyan:#38bdf8;--zb-border:#334155;}
+:root[data-zbhud="matrix"]{--zb-bg:#000500;--zb-bg2:#001a00;--zb-card:#002a00;--zb-hi:#003a00;--zb-text:#d4ffd4;--zb-dim:#7ccc7c;--zb-accent:#00ff41;--zb-cyan:#00ffcc;--zb-border:#004d00;}
+:root[data-zbhud="ember"]{--zb-bg:#0a0503;--zb-bg2:#1a0f05;--zb-card:#27150a;--zb-hi:#3a1f0f;--zb-text:#fed7aa;--zb-dim:#d97706;--zb-accent:#f97316;--zb-cyan:#fbbf24;--zb-border:#4a2c17;}
+:root[data-zbhud="arctic"]{--zb-bg:#020617;--zb-bg2:#0c1424;--zb-card:#0f1e33;--zb-hi:#1e2f4d;--zb-text:#e0f2fe;--zb-dim:#7dd3fc;--zb-accent:#60a5fa;--zb-cyan:#22d3ee;--zb-border:#1e3a5f;}
+:root[data-zbhud="crimson"]{--zb-bg:#0a0506;--zb-bg2:#140a0c;--zb-card:#1a0d10;--zb-hi:#2a1318;--zb-text:#ffe4e6;--zb-dim:#b08a92;--zb-accent:#e11d48;--zb-cyan:#2dd4bf;--zb-border:#3e1a22;}
+:root[data-zbhud="toxic"]{--zb-bg:#07090a;--zb-bg2:#0c0f0a;--zb-card:#0f130c;--zb-hi:#161b10;--zb-text:#e8ffd0;--zb-dim:#8a9a6a;--zb-accent:#c6ff00;--zb-cyan:#00e5ff;--zb-border:#2a3a1a;}
+:root[data-zbhud="vapor"]{--zb-bg:#0d0814;--zb-bg2:#140d1f;--zb-card:#1a1228;--zb-hi:#241836;--zb-text:#f0e6ff;--zb-dim:#a99cc4;--zb-accent:#ff6ec7;--zb-cyan:#72f1ff;--zb-border:#2e2142;}
+/* Map DevTools sys-color tokens onto the scheme key-colors (wins over host inline). */
+:root[data-zbhud] {
+  --sys-color-base: var(--zb-bg) !important;
+  --sys-color-surface: var(--zb-bg) !important;
+  --sys-color-surface1: var(--zb-bg2) !important;
+  --sys-color-surface2: var(--zb-card) !important;
+  --sys-color-surface3: var(--zb-hi) !important;
+  --sys-color-surface4: var(--zb-hi) !important;
+  --sys-color-surface5: var(--zb-hi) !important;
+  --sys-color-cdt-base-container: var(--zb-bg2) !important;
+  --sys-color-base-container: var(--zb-card) !important;
+  --sys-color-base-container-elevated: var(--zb-hi) !important;
+  --sys-color-surface-variant: var(--zb-card) !important;
+  --sys-color-neutral-container: var(--zb-card) !important;
+  --sys-color-omnibox-container: var(--zb-card) !important;
+  --sys-color-divider: var(--zb-border) !important;
+  --sys-color-on-surface: var(--zb-text) !important;
+  --sys-color-on-surface-subtle: var(--zb-dim) !important;
+  --sys-color-on-surface-secondary: var(--zb-dim) !important;
+  --sys-color-on-base: var(--zb-text) !important;
+  --sys-color-on-base-divider: var(--zb-border) !important;
+  --sys-color-primary: var(--zb-cyan) !important;
+  --sys-color-primary-bright: var(--zb-cyan) !important;
+  --sys-color-on-primary: var(--zb-bg) !important;
+  --sys-color-secondary: var(--zb-accent) !important;
+  --sys-color-tonal-container: var(--zb-hi) !important;
+  --sys-color-on-tonal-container: var(--zb-cyan) !important;
+  --sys-color-tonal-outline: var(--zb-border) !important;
+  --sys-color-outline: var(--zb-border) !important;
+  --sys-color-state-hover-on-subtle: var(--zb-hi) !important;
+  --sys-color-state-focus-highlight: var(--zb-border) !important;
+  --sys-color-inverse-surface: var(--zb-text) !important;
+  --sys-color-inverse-on-surface: var(--zb-bg) !important;
+  --sys-color-token-property-special: var(--zb-accent) !important;
+  --sys-color-token-variable: var(--zb-cyan) !important;
+}
