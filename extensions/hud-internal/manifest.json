{
  "manifest_version": 3,
  "name": "zwire HUD Internal",
  "version": "0.2.7",
  "description": "Cyberpunk HUD internal pages + 8-scheme picker for zwire.",
  "key": "",
  "permissions": [
    "storage",
    "nativeMessaging",
    "management",
    "tabs",
    "webNavigation",
    "history",
    "downloads",
    "bookmarks",
    "sessions",
    "alarms",
    "notifications",
    "developerPrivate",
    "settingsPrivate"
  ],
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "externally_connectable": {
    "ids": [
      "hpppdchpnphmiijdeanibpcadgknmaja"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pages/*",
        "schemes.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "chrome://extensions/*",
        "chrome://settings/*",
        "chrome://history/*",
        "chrome://bookmarks/*",
        "chrome://version/*"
      ],
      "js": [
        "redirect.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "chrome://*/*"
      ],
      "exclude_matches": [
        "chrome://extensions/*",
        "chrome://settings/*",
        "chrome://history/*",
        "chrome://bookmarks/*",
        "chrome://version/*",
        "chrome://newtab/*",
        "chrome://new-tab-page/*",
        "chrome://new-tab-page-third-party/*"
      ],
      "js": [
        "schemes.js",
        "theme.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*",
        "chrome://*/*"
      ],
      "exclude_matches": [
        "chrome://newtab/*",
        "chrome://new-tab-page/*",
        "chrome://new-tab-page-third-party/*"
      ],
      "js": [
        "schemes.js",
        "pages/fzf.js",
        "zfind.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*",
        "chrome://*/*"
      ],
      "exclude_matches": [
        "chrome://newtab/*",
        "chrome://new-tab-page/*",
        "chrome://new-tab-page-third-party/*"
      ],
      "js": [
        "schemes.js",
        "lib/zgui-core/webui/util.js",
        "lib/zgui-core/webui/fzf.js",
        "lib/zgui-core/webui/command-palette.js",
        "zpalette.js",
        "zvim.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*",
        "chrome://*/*"
      ],
      "exclude_matches": [
        "chrome://newtab/*",
        "chrome://new-tab-page/*",
        "chrome://new-tab-page-third-party/*"
      ],
      "js": [
        "schemes.js",
        "zstatus.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
