{
  "manifest_version": 3,
  "name": "zwire HUD Internal",
  "version": "0.6.26",
  "description": "Cyberpunk HUD internal pages + 8-scheme picker for zwire.",
  "key": "",
  "permissions": [
    "storage",
    "nativeMessaging",
    "management",
    "tabs",
    "webNavigation",
    "history",
    "downloads",
    "bookmarks",
    "sessions",
    "alarms",
    "notifications",
    "developerPrivate",
    "settingsPrivate",
    "system.display",
    "declarativeNetRequest",
    "browsingData",
    "tabGroups",
    "readingList",
    "power"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "frame_bust",
        "enabled": true,
        "path": "rules/frame_bust.json"
      }
    ]
  },
  "externally_connectable": {
    "ids": [
      "hpppdchpnphmiijdeanibpcadgknmaja",
      "gpoepnekoiplhkegjpocnpeijiefgieb"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "zwire HUD",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "open-palette": {
      "suggested_key": {
        "default": "Ctrl+K",
        "mac": "Command+K"
      },
      "description": "Open the zwire command palette"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pages/*",
        "schemes.js",
        "lib/term/*",
        "lib/zgui-core/webui/*.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "chrome://extensions/*",
        "chrome://settings/*",
        "chrome://history/*",
        "chrome://bookmarks/*",
        "chrome://version/*"
      ],
      "js": [
        "redirect.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ],
      "match_about_blank": true,
      "all_frames": false,
      "js": [
        "blank-newtab.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "chrome://*/*"
      ],
      "exclude_matches": [
        "chrome://extensions/*",
        "chrome://settings/*",
        "chrome://history/*",
        "chrome://bookmarks/*",
        "chrome://version/*",
        "chrome://newtab/*",
        "chrome://new-tab-page/*",
        "chrome://new-tab-page-third-party/*"
      ],
      "js": [
        "schemes.js",
        "theme.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "chrome://histograms/*",
        "chrome://policy/*",
        "chrome://components/*",
        "chrome://prefs-internals/*",
        "chrome://quota-internals/*",
        "chrome://indexeddb-internals/*",
        "chrome://blob-internals/*",
        "chrome://serviceworker-internals/*",
        "chrome://site-engagement/*",
        "chrome://predictors/*",
        "chrome://media-engagement/*",
        "chrome://gcm-internals/*",
        "chrome://ntp-tiles-internals/*",
        "chrome://web-app-internals/*",
        "chrome://app-service-internals/*",
        "chrome://autofill-internals/*",
        "chrome://attribution-internals/*",
        "chrome://translate-internals/*",
        "chrome://topics-internals/*",
        "chrome://download-internals/*",
        "chrome://gpu/*",
        "chrome://interstitials/*",
        "chrome://network-errors/*",
        "chrome://suggest-internals/*",
        "chrome://segmentation-internals/*",
        "chrome://metrics-internals/*",
        "chrome://local-state/*",
        "chrome://tab-strip-internals/*"
      ],
      "js": [
        "debug-cloak.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "chrome://histograms/*",
        "chrome://policy/*",
        "chrome://components/*",
        "chrome://prefs-internals/*",
        "chrome://quota-internals/*",
        "chrome://indexeddb-internals/*",
        "chrome://blob-internals/*",
        "chrome://serviceworker-internals/*",
        "chrome://site-engagement/*",
        "chrome://predictors/*",
        "chrome://media-engagement/*",
        "chrome://gcm-internals/*",
        "chrome://ntp-tiles-internals/*",
        "chrome://web-app-internals/*",
        "chrome://app-service-internals/*",
        "chrome://autofill-internals/*",
        "chrome://attribution-internals/*",
        "chrome://translate-internals/*",
        "chrome://topics-internals/*",
        "chrome://download-internals/*",
        "chrome://gpu/*",
        "chrome://interstitials/*",
        "chrome://network-errors/*",
        "chrome://suggest-internals/*",
        "chrome://segmentation-internals/*",
        "chrome://metrics-internals/*",
        "chrome://local-state/*",
        "chrome://tab-strip-internals/*"
      ],
      "css": [
        "lib/zgui-core/webui/data-table.css",
        "lib/zgui-core/webui/layout.css",
        "lib/zgui-core/webui/inspect.css",
        "lib/zgui-core/webui/widgets.css"
      ],
      "js": [
        "lib/zgui-core/webui/data-table.js",
        "lib/zgui-core/webui/card.js",
        "lib/zgui-core/webui/json-view.js",
        "debug-adapter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*",
        "chrome://*/*"
      ],
      "exclude_matches": [
        "chrome://newtab/*",
        "chrome://new-tab-page/*",
        "chrome://new-tab-page-third-party/*"
      ],
      "js": [
        "schemes.js",
        "pages/fzf.js",
        "zfind.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*",
        "chrome://*/*"
      ],
      "exclude_matches": [
        "chrome://newtab/*",
        "chrome://new-tab-page/*",
        "chrome://new-tab-page-third-party/*"
      ],
      "js": [
        "schemes.js",
        "lib/zgui-core/webui/util.js",
        "lib/zgui-core/webui/fzf.js",
        "lib/zgui-core/webui/command-palette.js",
        "zkeys.js",
        "cmd-defaults.js",
        "palette-cmds.js",
        "zpalette.js",
        "lib/zgui-core/webui/expose.js",
        "zexpose.js",
        "zvim.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*",
        "chrome://*/*"
      ],
      "exclude_matches": [
        "chrome://newtab/*",
        "chrome://new-tab-page/*",
        "chrome://new-tab-page-third-party/*"
      ],
      "css": [
        "lib/zgui-core/webui/powerline.css"
      ],
      "js": [
        "schemes.js",
        "lib/zgui-core/webui/powerline.js",
        "zpowerline.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ],
      "js": [
        "ztmux-pane.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ],
      "css": [
        "lib/zgui-core/webui/tmux.css",
        "ztmux-config.css"
      ],
      "js": [
        "schemes.js",
        "lib/zgui-core/webui/util.js",
        "lib/zgui-core/webui/split-pane.js",
        "lib/zgui-core/webui/modal.js",
        "lib/zgui-core/webui/toast.js",
        "lib/zgui-core/webui/button-bar.js",
        "lib/zgui-core/webui/tmux.js",
        "ztmux-config.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*",
        "chrome://*/*"
      ],
      "exclude_matches": [
        "chrome://newtab/*",
        "chrome://new-tab-page/*",
        "chrome://new-tab-page-third-party/*"
      ],
      "css": [
        "lib/term/xterm.css",
        "lib/term/terminal.css"
      ],
      "js": [
        "lib/zgui-core/webui/modal-drag.js",
        "lib/term/xterm.js",
        "lib/term/terminal.js",
        "lib/term/zterm-boot.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}